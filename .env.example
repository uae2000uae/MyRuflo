# Required for local dev. When hosted on GCP, leave this unset — the key is
# instead resolved from Secret Manager (see MYRUFLO_GCP_PROJECT below), or
# injected as this same env var via Cloud Run's --set-secrets binding.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- GCP hosting (Secret Manager) ---
# Every platform key can come from Secret Manager instead of env vars. When a
# GCP project is inferable (GOOGLE_CLOUD_PROJECT is set automatically on
# Cloud Run/GCE; set MYRUFLO_GCP_PROJECT for local testing), the app looks up
# these default secret IDs for any key not found in the environment:
#   ANTHROPIC_AI_KEY (or ANTHROPIC_API_KEY), OPENAI_API_KEY,
#   GEMINI_API_KEY (or GOOGLE_API_KEY), XAI_API_KEY (or GROK_API_KEY),
#   DEEPSEEK_API_KEY, MISTRAL_API_KEY
# Requires: pip install -e ".[gcp]"  (google-cloud-secret-manager)
# MYRUFLO_GCP_PROJECT=my-gcp-project-id
#
# Use different secret IDs per provider with MYRUFLO_SECRET_<PROVIDER>:
# MYRUFLO_SECRET_NAME=ANTHROPIC_AI_KEY   (anthropic, legacy name)
# MYRUFLO_SECRET_OPENAI=my-openai-secret-id
# MYRUFLO_SECRET_GEMINI=my-gemini-secret-id
# MYRUFLO_SECRET_XAI=my-xai-secret-id
# MYRUFLO_SECRET_DEEPSEEK=my-deepseek-secret-id
# MYRUFLO_SECRET_MISTRAL=my-mistral-secret-id

# --- Multi-platform routing ---
# MyRuflo routes each task to the best configured AI platform. Set any of the
# keys below to enable that platform; missing keys are skipped gracefully and
# the app runs fine with only ANTHROPIC_API_KEY set.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...            (or GOOGLE_API_KEY)
# XAI_API_KEY=...               (or GROK_API_KEY)
# DEEPSEEK_API_KEY=...
# MISTRAL_API_KEY=...
#
# On GCP, non-Anthropic keys can also come from Secret Manager: set
# MYRUFLO_SECRET_OPENAI=<secret-name> (likewise _GEMINI, _XAI, _DEEPSEEK,
# _MISTRAL) and the key is fetched from the project's Secret Manager.

# How platform choice is made:
#   auto  = a fast LLM classifies each task (type + complexity), then a routing
#           table picks the best configured platform (rules fallback on failure)
#   rules = keyword classifier only, no extra LLM call
#   off   = always use MYRUFLO_DEFAULT_PROVIDER
MYRUFLO_ROUTER=auto
MYRUFLO_DEFAULT_PROVIDER=anthropic

# Model routing (3-tier: fast/default/heavy) — see myruflo/config.py
MYRUFLO_MODEL_FAST=claude-haiku-4-5-20251001
MYRUFLO_MODEL_DEFAULT=claude-sonnet-5
MYRUFLO_MODEL_HEAVY=claude-opus-4-8
# Per-platform tier overrides: MYRUFLO_<PROVIDER>_MODEL_<TIER>, e.g.
# MYRUFLO_OPENAI_MODEL_HEAVY=gpt-5.5-pro
# MYRUFLO_GEMINI_MODEL_FAST=gemini-3.1-flash-lite
# MYRUFLO_XAI_MODEL_DEFAULT=grok-4.3
# MYRUFLO_DEEPSEEK_MODEL_HEAVY=deepseek-v4-pro
# MYRUFLO_MISTRAL_MODEL_DEFAULT=mistral-large-latest

# Where the agent is allowed to read/write files
MYRUFLO_WORKSPACE=./workspace

# Where memory.db and hooks.jsonl live
MYRUFLO_DATA_DIR=./data

# Shell tool is OFF by default — set to true to let agents run shell commands
MYRUFLO_ALLOW_SHELL=false

# Agent loop safety caps
MYRUFLO_MAX_TURNS=25
MYRUFLO_MAX_TOKENS=4096

# --- Web UI (`myruflo serve`) ---
# Signs session cookies. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# If left unset, a random key is generated each process start (fine for local dev,
# but logs everyone out on restart) - set a fixed value for anything long-lived.
WEB_SECRET_KEY=
MYRUFLO_WEB_HOST=0.0.0.0
MYRUFLO_WEB_PORT=8080
